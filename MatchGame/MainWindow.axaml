<Window
    Title="Find all of the matching animals"
    d:DesignHeight="450"
    d:DesignWidth="400"
    mc:Ignorable="d"
    x:Class="MatchGame.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid x:Name="MainGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            FontSize="36"
            Grid.Column="0"
            Grid.Row="0"
            HorizontalAlignment="Center"
            PointerPressed="TextBlock_PointerPressed"
            Text="?"
            TextWrapping="NoWrap"
            VerticalAlignment="Center" />
        <TextBlock
            FontSize="36"
            Grid.Column="1"
            Grid.Row="0"
            HorizontalAlignment="Center"
            PointerPressed="TextBlock_PointerPressed"
            Text="?"
            TextWrapping="NoWrap"
            VerticalAlignment="Center" />
        <TextBlock
            FontSize="36"
            Grid.Column="2"
            Grid.Row="0"
            HorizontalAlignment="Center"
            PointerPressed="TextBlock_PointerPressed"
            Text="?"
            TextWrapping="NoWrap"
            VerticalAlignment="Center" />
        <TextBlock
            FontSize="36"
            Grid.Column="3"
            Grid.Row="0"
            HorizontalAlignment="Center"
            PointerPressed="TextBlock_PointerPressed"
            Text="?"
            TextWrapping="NoWrap"
            VerticalAlignment="Center" />
        <TextBlock
            FontSize="36"
            Grid.Column="0"
            Grid.Row="1"
            HorizontalAlignment="Center"
            PointerPressed="TextBlock_PointerPressed"
            Text="?"
            TextWrapping="NoWrap"
            VerticalAlignment="Center" />
        <TextBlock
            FontSize="36"
            Grid.Column="1"
            Grid.Row="1"
            HorizontalAlignment="Center"
            PointerPressed="TextBlock_PointerPressed"
            Text="?"
            TextWrapping="NoWrap"
            VerticalAlignment="Center" />
        <TextBlock
            FontSize="36"
            Grid.Column="2"
            Grid.Row="1"
            HorizontalAlignment="Center"
            PointerPressed="TextBlock_PointerPressed"
            Text="?"
            TextWrapping="NoWrap"
            VerticalAlignment="Center" />
        <TextBlock
            FontSize="36"
            Grid.Column="3"
            Grid.Row="1"
            HorizontalAlignment="Center"
            PointerPressed="TextBlock_PointerPressed"
            Text="?"
            TextWrapping="NoWrap"
            VerticalAlignment="Center" />
        <TextBlock
            FontSize="36"
            Grid.Column="0"
            Grid.Row="2"
            HorizontalAlignment="Center"
            PointerPressed="TextBlock_PointerPressed"
            Text="?"
            TextWrapping="NoWrap"
            VerticalAlignment="Center" />
        <TextBlock
            FontSize="36"
            Grid.Column="1"
            Grid.Row="2"
            HorizontalAlignment="Center"
            PointerPressed="TextBlock_PointerPressed"
            Text="?"
            TextWrapping="NoWrap"
            VerticalAlignment="Center" />
        <TextBlock
            FontSize="36"
            Grid.Column="2"
            Grid.Row="2"
            HorizontalAlignment="Center"
            PointerPressed="TextBlock_PointerPressed"
            Text="?"
            TextWrapping="NoWrap"
            VerticalAlignment="Center" />
        <TextBlock
            FontSize="36"
            Grid.Column="3"
            Grid.Row="2"
            HorizontalAlignment="Center"
            PointerPressed="TextBlock_PointerPressed"
            Text="?"
            TextWrapping="NoWrap"
            VerticalAlignment="Center" />
        <TextBlock
            FontSize="36"
            Grid.Column="0"
            Grid.Row="3"
            HorizontalAlignment="Center"
            PointerPressed="TextBlock_PointerPressed"
            Text="?"
            TextWrapping="NoWrap"
            VerticalAlignment="Center" />
        <TextBlock
            FontSize="36"
            Grid.Column="1"
            Grid.Row="3"
            HorizontalAlignment="Center"
            PointerPressed="TextBlock_PointerPressed"
            Text="?"
            TextWrapping="NoWrap"
            VerticalAlignment="Center" />
        <TextBlock
            FontSize="36"
            Grid.Column="2"
            Grid.Row="3"
            HorizontalAlignment="Center"
            PointerPressed="TextBlock_PointerPressed"
            Text="?"
            TextWrapping="NoWrap"
            VerticalAlignment="Center" />
        <TextBlock
            FontSize="36"
            Grid.Column="3"
            Grid.Row="3"
            HorizontalAlignment="Center"
            PointerPressed="TextBlock_PointerPressed"
            Text="?"
            TextWrapping="NoWrap"
            VerticalAlignment="Center" />
    </Grid>
</Window>
